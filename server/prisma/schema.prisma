// QueueX — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ORG
  USER
}

enum QueueStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum EntryStatus {
  WAITING
  CALLED
  DONE
  LEFT
}

model Account {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user         User?
  organization Organization?

  @@map("accounts")
}

model User {
  id        String   @id @default(cuid())
  accountId String   @unique @map("account_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  queueEntries QueueEntry[]

  @@map("users")
}

model Organization {
  id          String   @id @default(cuid())
  accountId   String   @unique @map("account_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  queues  Queue[]

  @@map("organizations")
}

model Queue {
  id          String      @id @default(cuid())
  name        String
  orgId       String      @map("org_id")
  maxCapacity Int         @default(100) @map("max_capacity")
  serviceRate Float       @default(2.0) @map("service_rate")
  status      QueueStatus @default(ACTIVE)
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entries      QueueEntry[]

  @@map("queues")
}

model QueueEntry {
  id               String      @id @default(cuid())
  queueId          String      @map("queue_id")
  userId           String      @map("user_id")
  status           EntryStatus @default(WAITING)
  notifyAtPosition Int         @default(3) @map("notify_at_position")
  joinedAt         DateTime    @default(now()) @map("joined_at")
  calledAt         DateTime?   @map("called_at")
  completedAt      DateTime?   @map("completed_at")

  // Relations
  queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([queueId, userId])
  @@index([queueId, joinedAt])
  @@map("queue_entries")
}
